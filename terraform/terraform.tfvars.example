aws_region            = "us-east-1"
project               = "genorax"
environment           = "dev"
instance_type         = "t3.large"
root_volume_size      = 50
terraform_version     = "1.8.5"
public_key_path       = "~/.ssh/id_rsa.pub"

allowed_ssh_cidrs     = ["YOUR_PUBLIC_IP/32"]
allowed_jenkins_cidrs = ["YOUR_PUBLIC_IP/32"]

s3_bucket_arns = [
  "arn:aws:s3:::genorax-dev-uploads",
  "arn:aws:s3:::genorax-dev-results",
  "arn:aws:s3:::genorax-dev-reports"
]

passrole_arns = [
  "arn:aws:iam::123456789012:role/genorax-dev-ecs-task-execution-role",
  "arn:aws:iam::123456789012:role/genorax-dev-pipeline-task-role"
]

extra_tags = {
  Owner = "J"
}
